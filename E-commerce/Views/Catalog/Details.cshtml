@model ProductDetailsVM

@{
    ViewData["Title"] = Model.Product.Name;
}

<link rel="stylesheet" href="~/css/catalog.css" asp-append-version="true" />

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-controller="Catalog" asp-action="Index"
                                                       class="text-decoration-none text-muted hover-text-primary">Catalog</a></li>
                        @foreach (var cat in Model.CategoryBreadcrumb)
                        {
                            <li class="breadcrumb-item">
                                <a asp-controller="Catalog" asp-action="Index" asp-route-categoryId="@cat.CategoryId"
                                       class="text-decoration-none text-muted hover-text-primary">
                                    @cat.Name
                                </a>
                            </li>
                        }
                        <li class="breadcrumb-item active fw-medium text-dark" aria-current="page">@Model.Product.Name</li>
                    </ol>
                </nav>

                <div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 border-top border-4 border-primary bg-white">
                
                    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
                        @if (Model.Product.Category != null)
                        {
                            <span class="badge bg-light text-primary text-uppercase px-3 py-2 rounded-pill fw-bold"
                                  style="font-size: 0.75rem; letter-spacing: 0.5px;">
                                @Model.Product.Category.Name
                            </span>
                        }
                        <span class="text-muted small fw-medium">
                            <i class="bi bi-upc-scan me-1"></i> SKU: @Model.Product.SKU
                        </span>
                    </div>

                    <h1 class="display-6 fw-bold text-dark mb-3">@Model.Product.Name</h1>

                    <div class="d-flex align-items-center flex-wrap gap-4 mb-4 pb-3 border-bottom border-light">
                        <h2 class="text-primary fw-bolder mb-0 display-5">$@Model.Product.Price.ToString("F2")</h2>
                    
                        <div class="vr text-muted opacity-25 d-none d-sm-block" style="width: 2px;"></div>
                    
                        @if (Model.Product.StockQuantity > 0)
                        {
                            <div
                                class="d-flex align-items-center text-success bg-success bg-opacity-10 px-3 py-2 rounded-3 fw-semibold">
                                <i class="bi bi-check-circle-fill me-2 fs-5"></i>
                                <div>
                                    <span class="d-block lh-1">In Stock</span>
                                    <small class="fw-normal opacity-75">@Model.Product.StockQuantity available</small>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div
                                class="d-flex align-items-center text-danger bg-danger bg-opacity-10 px-3 py-2 rounded-3 fw-semibold">
                                <i class="bi bi-x-circle-fill me-2 fs-5"></i>
                                <span class="lh-1">Out of Stock</span>
                            </div>
                        }
                    </div>

                    <form asp-controller="Cart" asp-action="Add" method="post" class="bg-light p-4 rounded-4 mt-2">
                        
                        <input type="hidden" name="productId" value="@Model.Product.ProductId" />
                        
                        <div class="row g-3 align-items-end">
                            <div class="col-sm-4 col-md-3">
                                <label for="quantity" class="form-label fw-semibold text-dark small mb-2">Quantity</label>
                                <div
                                    class="input-group input-group-lg bg-white rounded-3 shadow-sm border border-light overflow-hidden">
                                    <input type="number" name="count" id="quantity"
                                           class="form-control border-0 text-center fw-bold shadow-none qty-input"
                                           value="@Model.Count" min="1" max="@Model.Product.StockQuantity"
                                    @(Model.Product.StockQuantity <= 0 ? "disabled" : "")>
                                </div>
                            </div>
                        
                            <div class="col-sm-8 col-md-9">
                                <button type="submit"
                                        class="btn btn-primary btn-lg w-100 rounded-3 fw-bold shadow-sm d-flex justify-content-center align-items-center gap-2 btn-cart transition-all"
                                    @(Model.Product.StockQuantity <= 0 ? "disabled" : "")>
                                    <i class="bi bi-cart-plus fs-5"></i>
                                    @(Model.Product.StockQuantity > 0 ? "Add to Cart" : "Currently Unavailable")
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>