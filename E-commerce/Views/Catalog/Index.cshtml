@model ProductListVM

@{
    ViewData["Title"] = "Product Catalog";
}

<link rel="stylesheet" href="~/css/catalog.css" asp-append-version="true" />

<div class="container-fluid py-4">
    <div class="row g-4">
        <div class="col-lg-3 col-md-4">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden sticky-top" style="top: 2rem;">
                <div class="card-header bg-white border-0 pt-4 pb-0 px-4">
                    <h6 class="text-uppercase fw-bold text-muted mb-0"><i class="bi bi-grid-fill me-2"></i> Categories
                    </h6>
                </div>
                <div class="card-body p-3">
                    <div class="nav flex-column nav-pills gap-1">
                        <a asp-controller="Catalog" asp-action="Index"
                               class="nav-link px-3 py-2 rounded-3 text-dark transition-all @(Model.CurrentCategoryId == null ? "active bg-primary text-white shadow-sm" : "hover-bg-light")">
                            All Products
                        </a>
                        @await Component.InvokeAsync("CategoryTree", new { categories = Model.Categories, currentCategoryId = Model.CurrentCategoryId })
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-9 col-md-8">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-2">
                    <form asp-controller="Catalog" asp-action="Index" method="get" class="d-flex align-items-center">
                        <div class="input-group input-group-lg border-0">
                            <span class="input-group-text bg-transparent border-0 text-muted px-3">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" name="q"
                                   class="form-control border-0 shadow-none bg-transparent fs-6 search-input"
                                   placeholder="Search for products, brands, and more..." value="@Model.SearchQuery">
                            
                            @if (Model.CurrentCategoryId.HasValue)
                            {
                                <input type="hidden" name="categoryId" value="@Model.CurrentCategoryId.Value">
                            }
                            
                            @if (!string.IsNullOrEmpty(Model.SearchQuery))
                            {
                                <a asp-controller="Catalog" asp-action="Index"
                                       asp-route-categoryId="@Model.CurrentCategoryId"
                                       class="btn text-muted hover-text-danger px-3 d-flex align-items-center shadow-none btn-clear-search">
                                    <i class="bi bi-x-circle-fill"></i>
                                </a>
                            }
                            <button type="submit" class="btn btn-primary rounded-3 px-4 fw-medium m-1">Search</button>
                        </div>
                    </form>
                </div>
            </div>

            @if (Model.Products.Any())
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                    @foreach (var product in Model.Products)
                    {
                        <div class="col">
                            <div
                                class="card h-100 border-0 shadow-sm rounded-4 product-card p-4 border-top border-4 border-primary">
                                
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <span class="badge bg-light text-primary text-uppercase px-3 py-2 rounded-pill fw-bold"
                                          style="font-size: 0.7rem; letter-spacing: 0.5px;">
                                        @product.Category?.Name
                                    </span>
                                    
                                    @if (product.StockQuantity > 0)
                                    {
                                        <span class="text-success small fw-semibold d-flex align-items-center">
                                            <i class="bi bi-check-circle-fill me-1"></i> In Stock
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-danger small fw-semibold d-flex align-items-center">
                                            <i class="bi bi-x-circle-fill me-1"></i> Out of Stock
                                        </span>
                                    }
                                </div>

                                <h5 class="card-title fw-bold text-dark mb-4 line-clamp-3 lh-base">@product.Name</h5>
                                
                                <div
                                    class="mt-auto d-flex align-items-center justify-content-between pt-3 border-top border-light">
                                    <h4 class="text-primary fw-bolder mb-0">$@product.Price.ToString("F2")</h4>
                                    
                                    <div class="d-flex gap-2">
                                        <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline">
                                            <input type="hidden" name="productId" value="@product.ProductId" />
                                            <input type="hidden" name="count" value="1" /> 
                                            <button type="submit" 
                                                    class="btn btn-success rounded-circle p-2 d-flex align-items-center justify-content-center transition-all shadow-sm"
                                                    title="Quick Add to Cart" style="width: 40px; height: 40px;"
                                                    @(product.StockQuantity <= 0 ? "disabled" : "")>
                                                <i class="bi bi-cart-plus fs-5 lh-1"></i>
                                            </button>
                                        </form>

                                        <a asp-controller="Catalog" asp-action="Details" asp-route-id="@product.ProductId"
                                               class="btn btn-light rounded-circle p-2 btn-view-details text-primary d-flex align-items-center justify-content-center transition-all"
                                               title="View Details" style="width: 40px; height: 40px;">
                                            <i class="bi bi-arrow-right fs-5 lh-1"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (Model.TotalPages > 1)
                {
                    <nav aria-label="Product pagination" class="mt-5">
                        <ul class="pagination justify-content-center gap-2 border-0">
                            <li class="page-item @(Model.CurrentPage == 1 ? "disabled" : "")">
                                <a class="page-link rounded-circle border-0 shadow-sm" asp-controller="Catalog"
                                       asp-action="Index" asp-route-page="1" asp-route-categoryId="@Model.CurrentCategoryId"
                                       asp-route-q="@Model.SearchQuery">
                                    <i class="bi bi-chevron-double-left"></i>
                                </a>
                            </li>
                            @for (int i = 1; i <= Model.TotalPages; i++)
                            {
                                <li class="page-item @(Model.CurrentPage == i ? "active" : "")">
                                    <a class="page-link rounded-circle border-0 shadow-sm fw-medium px-3" asp-controller="Catalog"
                                       asp-action="Index" asp-route-page="@i" asp-route-categoryId="@Model.CurrentCategoryId"
                                       asp-route-q="@Model.SearchQuery">@i</a>
                                </li>
                            }
                            <li class="page-item @(Model.CurrentPage == Model.TotalPages ? "disabled" : "")">
                                <a class="page-link rounded-circle border-0 shadow-sm" asp-controller="Catalog"
                                       asp-action="Index" asp-route-page="@Model.TotalPages"
                                       asp-route-categoryId="@Model.CurrentCategoryId" asp-route-q="@Model.SearchQuery">
                                    <i class="bi bi-chevron-double-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="card border-0 shadow-sm rounded-4 text-center py-5">
                    <div class="card-body py-5">
                        <i class="bi bi-search text-muted opacity-25 display-1 mb-4 d-block"></i>
                        <h3 class="fw-bold text-dark">No products found</h3>
                        <p class="text-muted mb-4">We couldn't find anything matching your search criteria.</p>
                        <a asp-action="Index" class="btn btn-outline-primary rounded-pill px-4">Clear all filters</a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Expand parent collapses for the active item
            var activeLink = document.querySelector('.category-item .active');
            if (activeLink) {
                var current = activeLink.closest('.collapse');
                while (current) {
                    current.classList.add('show');
                    var toggleBtn = document.querySelector('[data-bs-target="#' + current.id + '"]');
                    if (toggleBtn) {
                        toggleBtn.setAttribute('aria-expanded', 'true');
                        var icon = toggleBtn.querySelector('i');
                        if (icon) {
                            icon.classList.remove('bi-chevron-down');
                            icon.classList.add('bi-chevron-up');
                        }
                    }
                    current = current.parentElement.closest('.collapse');
                }
            }

            // Toggle icon on collapse show/hide
            var collapses = document.querySelectorAll('.category-item .collapse');
            collapses.forEach(function (collapse) {
                collapse.addEventListener('show.bs.collapse', function (e) {
                    // Prevent bubbling from nested collapses
                    if (e.target !== this) return;
                    var toggleBtn = document.querySelector('[data-bs-target="#' + this.id + '"]');
                    if (toggleBtn) {
                        var icon = toggleBtn.querySelector('i');
                        if (icon) {
                            icon.classList.remove('bi-chevron-down');
                            icon.classList.add('bi-chevron-up');
                        }
                    }
                });

                collapse.addEventListener('hide.bs.collapse', function (e) {
                    // Prevent bubbling from nested collapses
                    if (e.target !== this) return;
                    var toggleBtn = document.querySelector('[data-bs-target="#' + this.id + '"]');
                    if (toggleBtn) {
                        var icon = toggleBtn.querySelector('i');
                        if (icon) {
                            icon.classList.remove('bi-chevron-up');
                            icon.classList.add('bi-chevron-down');
                        }
                    }
                });
            });
        });
    </script>
}