@using Microsoft.AspNetCore.Identity
@using E_commerceEntity.Entity

@inject SignInManager<APP_User> SignInManager
@inject UserManager<APP_User> UserManager

<ul class="navbar-nav align-items-center">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a id="manage" class="nav-link text-dark fw-medium px-3" src="#" >
            <i class="bi bi-person-circle me-1"></i> @UserManager.GetUserName(User)
        </a>
    </li>
    <li class="nav-item">
        <form id="logoutForm" class="form-inline m-0 p-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button id="logout" type="submit" class="nav-link bg-transparent border-0 text-dark fw-medium px-3">
                Logout
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-dark fw-medium px-3" id="login" asp-area="Identity" asp-page="/Account/Login">
            Login
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link text-dark fw-medium px-3" id="register" asp-area="Identity" asp-page="/Account/Register">
            Register
        </a>
    </li>
}
</ul>
