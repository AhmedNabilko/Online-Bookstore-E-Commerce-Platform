@model IEnumerable<Category>
@{
    ViewData["Title"] = "Categories";
}

<div class="card shadow-sm border-0 rounded-4 mt-4">
    <div class="card-body p-4">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold text-dark mb-0">Category Management</h3>
            <span class="badge bg-secondary rounded-pill px-3 py-2 fs-6">Total Categories: @Model.Count()</span>
        </div>

        <div class="row pb-4 align-items-center">
            <div class="col-md-6 mb-3 mb-md-0">
                <form asp-action="Index" method="get" class="d-flex">
                    <input type="text" name="search" value="@ViewData["CurrentSearch"]" class="form-control rounded-pill me-2 shadow-sm" placeholder="Search by name..." />
                    <button type="submit" class="btn btn-dark rounded-pill px-4 shadow-sm">Search</button>
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 ms-2 shadow-sm">Clear</a>
                </form>
            </div>
            <div class="col-md-6 text-md-end">
                <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
                    <i class="bi bi-plus-circle me-1"></i> Create New Category
                </a>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle border-bottom">
                <thead class="table-light text-uppercase text-muted" style="font-size: 0.85rem; letter-spacing: 0.5px;">
                    <tr>
                        <th class="ps-3">Category Name</th>
                        <th>Parent Category</th>
                        <th class="text-center pe-3">Actions</th>
                    </tr>
                </thead>
            <tbody class="border-top-0">
                @if (Model.Any())
                {
                    @foreach (var obj in Model.OrderBy(u => u.Name))
                    {
                        <tr>
                            <td class="ps-3 fw-semibold">@obj.Name</td>
                            <td class="text-muted">@(obj.ParentCategory?.Name ?? "None")</td>
                            <td class="text-center pe-3">
                                <a asp-action="Edit" asp-route-id="@obj.CategoryId" class="btn btn-outline-primary btn-sm rounded-pill px-3 mx-1">
                                    <i class="bi bi-pencil-square me-1"></i> Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@obj.CategoryId" class="btn btn-outline-danger btn-sm rounded-pill px-3 mx-1">
                                    <i class="bi bi-trash-fill me-1"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center py-5 text-muted">
                            <i class="bi bi-folder-x fs-1 d-block mb-2"></i>
                            No categories found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
    </div>
</div>
