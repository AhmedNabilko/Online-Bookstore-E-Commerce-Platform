@model E_commerce.Models.ViewModels.OrderDetailsVM
@{
    ViewData["Title"] = $"Order #{Model.OrderNumber}";
}

<div class="container-fluid px-0 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-0">Order <span class="text-primary">#@Model.OrderNumber</span></h2>
            <small class="text-muted">Placed on @Model.OrderDate.ToString("MMMM dd, yyyy 'at' HH:mm")</small>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
            <i class="bi bi-arrow-left me-2"></i> Back to Orders
        </a>
    </div>

    

    <div class="row g-4 mb-4">
        
        <div class="col-lg-4">
            <div class="card h-100 shadow-sm border-0 rounded-4">
                <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0"><i class="bi bi-receipt text-primary me-2"></i> Order Status</h5>
                </div>
                <div class="card-body p-4">
                    <div class="mb-4">
                        <label class="text-muted small fw-bold text-uppercase mb-2">Current Status</label>
                        
                        <form asp-action="UpdateStatus" method="post" class="d-flex align-items-center">
                            <input type="hidden" name="orderId" value="@Model.OrderId" />
                            <select name="status" class="form-select shadow-none border-secondary me-2">
                                @foreach (var status in (IEnumerable<SelectListItem>)ViewBag.StatusList)
                                {
                                    if (Model.Status.ToString() == status.Value)
                                    {
                                        <option value="@status.Value" selected>@status.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@status.Value">@status.Text</option>
                                    }
                                }
                            </select>
                            <button type="submit" class="btn btn-primary px-3">Update</button>
                        </form>
                    </div>
                    <ul class="list-group list-group-flush mt-3">
                        <li class="list-group-item px-0 d-flex justify-content-between align-items-center border-0 pb-1">
                            <span class="text-muted">Order ID</span>
                            <span class="fw-semibold">@Model.OrderId</span>
                        </li>
                        <li class="list-group-item px-0 d-flex justify-content-between align-items-center border-0 pt-1">
                            <span class="text-muted">Total Amount</span>
                            <span class="fw-bold text-success fs-5">@Model.TotalAmount.ToString("C")</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card h-100 shadow-sm border-0 rounded-4">
                <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0"><i class="bi bi-person text-primary me-2"></i> Customer Info</h5>
                </div>
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <div class="bg-light rounded-circle p-3 me-3 text-primary">
                            <i class="bi bi-person-fill fs-4"></i>
                        </div>
                        <div>
                            <h6 class="fw-bold mb-0">@Model.CustomerName</h6>
                            <a href="mailto:@Model.CustomerEmail" class="text-decoration-none text-muted small">@Model.CustomerEmail</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card h-100 shadow-sm border-0 rounded-4">
                <div class="card-header bg-transparent border-bottom-0 pt-4 pb-0 px-4">
                    <h5 class="fw-bold mb-0"><i class="bi bi-truck text-primary me-2"></i> Shipping Destination</h5>
                </div>
                <div class="card-body p-4">
                    @if (Model.ShippingAddress != null)
                    {
                        <address class="mb-0 text-muted">
                            <span class="d-block text-dark fw-semibold mb-1">@Model.CustomerName</span>
                            @Model.ShippingAddress.Street<br>
                            @Model.ShippingAddress.City, @Model.ShippingAddress.Zip<br>
                            @Model.ShippingAddress.Country
                        </address>
                    }
                    else
                    {
                        <span class="text-danger fst-italic">No shipping address provided.</span>
                    }
                </div>
            </div>
        </div>

    </div>

    <div class="card shadow-sm border-0 rounded-4 mb-5">
        <div class="card-header bg-transparent border-bottom pt-4 pb-3 px-4">
            <h5 class="fw-bold mb-0"><i class="bi bi-box-seam text-primary me-2"></i> Purchased Items</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4 py-3">Product Name</th>
                            <th class="text-center py-3">Quantity</th>
                            <th class="text-end py-3">Unit Price</th>
                            <th class="text-end pe-4 py-3">Line Total</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @if (Model.Items != null && Model.Items.Any())
                        {
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td class="ps-4 py-3 fw-semibold">@item.ProductName</td>
                                    <td class="text-center py-3">
                                        <span class="badge bg-secondary rounded-pill px-3">@item.Quantity</span>
                                    </td>
                                    <td class="text-end py-3 text-muted">@item.UnitPrice.ToString("C")</td>
                                    <td class="text-end pe-4 py-3 fw-bold">@item.LineTotal.ToString("C")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-cart-x fs-2 d-block mb-2"></i>
                                    No items found for this order.
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="bg-light">
                        <tr>
                            <td colspan="3" class="text-end py-3 fw-bold text-uppercase small text-muted">Total Amount:</td>
                            <td class="text-end pe-4 py-3 fw-bold text-success fs-5">@Model.TotalAmount.ToString("C")</td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>
</div>