@model Order
@{
    ViewData["Title"] = "Update Order Status";
}

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Update Order Status</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="OrderId" />
            <input type="hidden" asp-for="OrderNumber" />
            <input type="hidden" asp-for="OrderDate" />
            <input type="hidden" asp-for="TotalAmount" />
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="AddressId" />

            <div class="row">
                <div class="col-md-6 offset-md-3">
                    <div class="mb-3">
                        <label asp-for="OrderNumber" class="form-label fw-bold">Order Number</label>
                        <input asp-for="OrderNumber" class="form-control" disabled />
                    </div>

                    <div class="mb-3">
                        <label asp-for="OrderDate" class="form-label fw-bold">Order Date</label>
                        <input asp-for="OrderDate" class="form-control" disabled />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Status" class="form-label fw-bold">Status</label>
                        <select asp-for="Status" class="form-select" asp-items="ViewBag.StatusList">
                        </select>
                        <span asp-validation-for="Status" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="TotalAmount" class="form-label fw-bold">Total Amount</label>
                        <input asp-for="TotalAmount" class="form-control" disabled />
                    </div>

                    <div class="row mt-4">
                        <div class="col-6">
                            <button type="submit" class="btn btn-primary w-100">
                                <i class="bi bi-check-circle"></i> Update Status
                            </button>
                        </div>
                        <div class="col-6">
                            <a asp-action="Details" asp-route-id="@Model.OrderId" class="btn btn-secondary w-100">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
