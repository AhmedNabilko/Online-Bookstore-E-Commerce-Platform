@model ProductVM
@{
    ViewData["Title"] = "Delete Product";
}

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Delete Product</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <form asp-action="Delete" method="post" class="row">
            <input asp-for="ProductId" hidden />
            <div class="border p-3 mt-4 shadow-sm rounded">
                <div class="row pb-2">
                    <h4 class="text-primary">Are you sure you want to delete this product?</h4>
                    <hr />
                </div>
                
                <div class="form-floating py-2 col-12">
                    <input asp-for="Name" disabled class="form-control border-0 shadow" />
                    <label asp-for="Name" class="ms-2"></label>
                </div>

                <div class="form-floating py-2 col-12">
                    <input asp-for="SKU" disabled class="form-control border-0 shadow" />
                    <label asp-for="SKU" class="ms-2"></label>
                </div>

                <div class="form-floating py-2 col-12">
                    <input asp-for="CategoryName" disabled class="form-control border-0 shadow" />
                    <label asp-for="CategoryName" class="ms-2"></label>
                </div>

                <div class="row">
                    <div class="form-floating py-2 col-6">
                        <input asp-for="Price" disabled class="form-control border-0 shadow" />
                        <label asp-for="Price" class="ms-2"></label>
                    </div>

                    <div class="form-floating py-2 col-6">
                        <input asp-for="StockQuantity" disabled class="form-control border-0 shadow" />
                        <label asp-for="StockQuantity" class="ms-2"></label>
                    </div>
                </div>

                <div class="row mt-3">
                    <div class="col-6 col-md-3">
                        <button type="submit" class="btn btn-danger form-control">Delete</button>
                    </div>
                    <div class="col-6 col-md-3">
                        <a asp-action="Index" class="btn btn-outline-secondary border form-control">
                            Back to List
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>
