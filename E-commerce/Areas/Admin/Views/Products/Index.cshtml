@model IEnumerable<ProductVM>
@{
    ViewData["Title"] = "Products";
    int pageNumber = (int)ViewData["PageNumber"];
    int totalCount = (int)ViewData["TotalCount"];
    int pageSize = (int)ViewData["PageSize"];
    int totalPages = (int)Math.Ceiling((double)totalCount / pageSize);
    string search = ViewData["CurrentSearch"] as string;
}

<div class="card shadow-sm border-0 rounded-4 mt-4">
    <div class="card-body p-4">
        
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h3 class="fw-bold text-dark mb-0">Product Management</h3>
            <span class="badge bg-secondary rounded-pill px-3 py-2 fs-6">Total Products: @totalCount</span>
        </div>

        <div class="row pb-4 align-items-center">
            <div class="col-md-6 mb-3 mb-md-0">
                <form asp-action="Index" method="get" class="d-flex">
                    <input type="text" name="search" value="@search" class="form-control rounded-pill me-2 shadow-sm" placeholder="Search by name..." />
                    <button type="submit" class="btn btn-dark rounded-pill px-4 shadow-sm">Search</button>
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 ms-2 shadow-sm">Clear</a>
                </form>
            </div>
            <div class="col-md-6 text-md-end">
                <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
                    <i class="bi bi-plus-circle me-1"></i> Create New Product
                </a>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle border-bottom">
                <thead class="table-light text-uppercase text-muted" style="font-size: 0.85rem; letter-spacing: 0.5px;">
                    <tr>
                        <th class="ps-3">Name</th>
                        <th>SKU</th>
                        <th>Category</th>
                        <th class="text-end">Price</th>
                        <th class="text-center">Stock</th>
                        <th class="text-center">Status</th>
                        <th class="text-center pe-3">Actions</th>
                    </tr>
                </thead>
            <tbody class="border-top-0">
                @if (Model.Any())
                {
                    @foreach (var obj in Model)
                    {
                        <tr>
                            <td class="ps-3 fw-semibold">@obj.Name</td>
                            <td class="text-muted"><small>@obj.SKU</small></td>
                            <td>@obj.CategoryName</td>
                            <td class="text-end">@obj.Price.ToString("C")</td>
                            <td class="text-center">@obj.StockQuantity</td>
                            <td class="text-center">
                                @if (obj.IsActive)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inactive</span>
                                }
                            </td>
                            <td class="text-center pe-3">
                                <a asp-action="Edit" asp-route-id="@obj.ProductId" class="btn btn-outline-primary btn-sm rounded-pill px-3 mx-1">
                                    <i class="bi bi-pencil-square me-1"></i> Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@obj.ProductId" class="btn btn-outline-danger btn-sm rounded-pill px-3 mx-1">
                                    <i class="bi bi-trash-fill me-1"></i> Delete
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-5 text-muted">
                            <i class="bi bi-box fs-1 d-block mb-2"></i>
                            No products found.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>

        @if (totalPages > 1)
        {
            <nav aria-label="Page navigation">
                <ul class="pagination justify-content-center mt-4">
                    <li class="page-item @(pageNumber == 1 ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@(pageNumber - 1)" asp-route-search="@search">Previous</a>
                    </li>
                    @for (int i = 1; i <= totalPages; i++)
                    {
                        <li class="page-item @(i == pageNumber ? "active" : "")">
                            <a class="page-link" asp-action="Index" asp-route-pageNumber="@i" asp-route-search="@search">@i</a>
                        </li>
                    }
                    <li class="page-item @(pageNumber == totalPages ? "disabled" : "")">
                        <a class="page-link" asp-action="Index" asp-route-pageNumber="@(pageNumber + 1)" asp-route-search="@search">Next</a>
                    </li>
                </ul>
            </nav>
        }
    </div>
</div>
