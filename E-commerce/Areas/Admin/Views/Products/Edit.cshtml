@model ProductVM
@{
    ViewData["Title"] = "Edit Product";
}

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Edit Product</h2>
            </div>
        </div>
    </div>
    <div class="card-body p-4">
        <form asp-action="Edit" method="post" class="row">
            <input asp-for="ProductId" hidden />
            <div class="border p-3 mt-4 shadow-sm rounded">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="form-floating py-2 col-12">
                    <input asp-for="Name" class="form-control border-0 shadow" placeholder="Product Name" />
                    <label asp-for="Name" class="ms-2"></label>
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-floating py-2 col-12">
                    <input asp-for="SKU" class="form-control border-0 shadow" placeholder="SKU" />
                    <label asp-for="SKU" class="ms-2"></label>
                    <span asp-validation-for="SKU" class="text-danger"></span>
                </div>

                <div class="form-floating py-2 col-12">
                    <select asp-for="CategoryId" asp-items="@Model.CategoryList" class="form-select border-0 shadow">
                        <option disabled>--Select Category--</option>
                    </select>
                    <label asp-for="CategoryId" class="ms-2"></label>
                    <span asp-validation-for="CategoryId" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="form-floating py-2 col-6">
                        <input asp-for="Price" type="number" step="0.01" class="form-control border-0 shadow" placeholder="Price" />
                        <label asp-for="Price" class="ms-2"></label>
                        <span asp-validation-for="Price" class="text-danger"></span>
                    </div>

                    <div class="form-floating py-2 col-6">
                        <input asp-for="StockQuantity" type="number" class="form-control border-0 shadow" placeholder="Stock Quantity" />
                        <label asp-for="StockQuantity" class="ms-2"></label>
                        <span asp-validation-for="StockQuantity" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-check py-3 col-12 ms-2">
                    <input asp-for="IsActive" class="form-check-input shadow" />
                    <label asp-for="IsActive" class="form-check-label ms-1">Active</label>
                </div>

                <div class="row mt-3">
                    <div class="col-6 col-md-3">
                        <button type="submit" class="btn btn-primary form-control">Update</button>
                    </div>
                    <div class="col-6 col-md-3">
                        <a asp-action="Index" class="btn btn-outline-secondary border form-control">
                            Back to List
                        </a>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
